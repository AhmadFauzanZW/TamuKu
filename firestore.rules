rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Guests — Tamu ────────────────────────────────────────────────
    match /guests/{guestId} {
      // Tamu boleh submit form tanpa login
      allow create: if true;
      // Admin yang login bisa baca semua data tamu
      allow read: if request.auth != null;
      // Update/hapus hanya yang login
      allow update, delete: if request.auth != null;
    }

    // ── Locations — Lokasi ───────────────────────────────────────────
    match /locations/{locationId} {
      // QR code perlu diakses publik (guest scan)
      allow read: if true;
      // Admin yang login bisa semua operasi write
      allow write: if request.auth != null;
    }

    // ── Hosts — Admin/User ───────────────────────────────────────────
    match /hosts/{hostId} {
      // Admin yang login boleh baca semua host
      allow read: if request.auth != null;
      // Bisa update diri sendiri atau siapa saja
      allow update: if request.auth != null;
      // Bisa buat host baru
      allow create: if request.auth != null;
      // Tidak boleh hapus host
      allow delete: if false;
    }
  }
}
