rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    // Safe role check — handles missing doc without crashing
    function getUserRole() {
      let host = get(/databases/$(database)/documents/hosts/$(request.auth.uid));
      return host.data != null ? host.data.role : '';
    }

    function isSuperAdmin() {
      return getUserRole() == 'super_admin';
    }

    function isAdmin() {
      return getUserRole() == 'admin';
    }

    function isSuperAdminOrAdmin() {
      return isSuperAdmin() || isAdmin();
    }

    // Safe location management check
    function managesLocation(locId) {
      let host = get(/databases/$(database)/documents/hosts/$(request.auth.uid));
      return isSuperAdmin()
        || (isAuth() && host.data != null && locId in host.data.locations);
    }

    // ── Guests — Tamu ────────────────────────────────────────────────
    match /guests/{guestId} {
      // Guest form submission (no auth required)
      allow create: if true;
      // Admin/host can read guests
      allow read: if isAuth();
      // Update:
      //   - Unauthenticated: guest checkout — must set status, checkOutTime, and photoUrl
      //   - Authenticated: admin/host of the location (full update)
      allow update: if
        (!isAuth()
          && request.resource.data.status == 'checked_out'
          && request.resource.data.checkOutTime != null
          && request.resource.data.photoUrl != null)
        ||
        (isAuth() && (isSuperAdminOrAdmin() || managesLocation(resource.data.locationId)));
      // Delete: super_admin only
      allow delete: if isSuperAdmin();
    }

    // ── Locations — Lokasi ───────────────────────────────────────────
    match /locations/{locationId} {
      // QR code public read (guest scan)
      allow read: if true;
      // Create/delete: super_admin only
      allow create, delete: if isSuperAdmin();
      // Update: super_admin or admin of the location
      allow update: if isAuth() && (isSuperAdminOrAdmin() || managesLocation(locationId));
    }

    // ── Hosts — Admin/User ───────────────────────────────────────────
    match /hosts/{hostId} {
      // Admin can read all hosts
      allow read: if isAuth();
      // Create: super_admin only
      allow create: if isSuperAdmin();
      // Update: super_admin, or user updating own profile
      allow update: if isAuth() && (isSuperAdmin() || request.auth.uid == hostId);
      // No one can delete hosts
      allow delete: if false;
    }
  }
}
