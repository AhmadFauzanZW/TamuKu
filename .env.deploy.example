# ═══════════════════════════════════════════════
# TamuKu — Deployment Environment Variables
# Copy this to Dokploy service env or .env files
# ═══════════════════════════════════════════════

# ─── Backend Service (Dokploy: tamuku-backend) ───
PORT=3000
HOST=0.0.0.0
API_KEY=<GENERATE_PRODUCTION_KEY>

# Contabo S3
S3_ENDPOINT=sg.contabostorage.com
S3_ACCESS_KEY=<YOUR_CONTABO_S3_ACCESS_KEY>
S3_SECRET_KEY=<YOUR_CONTABO_S3_SECRET_KEY>
S3_BUCKET=tamuku-guest-photos
S3_USE_SSL=true

# Firebase Admin SDK
FIREBASE_SERVICE_ACCOUNT_PATH=/app/serviceAccountKey.json

# Telegram Bot
TELEGRAM_BOT_TOKEN=<YOUR_TELEGRAM_BOT_TOKEN>
TELEGRAM_CHAT_ID=<YOUR_TELEGRAM_CHAT_ID>

# ─── Admin Web Service (Dokploy: tamuku-admin-web) ───
# These are VITE_ build-time args — set in Dokploy build settings
VITE_FIREBASE_API_KEY=<FIREBASE_API_KEY>
VITE_FIREBASE_AUTH_DOMAIN=tamuku-6360f.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tamuku-6360f
VITE_FIREBASE_STORAGE_BUCKET=tamuku-6360f.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=<FCM_SENDER_ID>
VITE_FIREBASE_APP_ID=<FIREBASE_APP_ID>
VITE_BACKEND_URL=https://tamuku.chronaxis.site
VITE_API_KEY=<SAME_API_KEY_AS_BACKEND>
